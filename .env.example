# ============================================================
# AI-Powered Secure Code Review Platform — Environment Config
# ============================================================
# Copy this file to .env and fill in your values.

# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── Application ────────────────────────────────────────────
SECRET_KEY=
ENVIRONMENT=
ALLOWED_ORIGINS=

# ─── AI Engine ──────────────────────────────────────────────
GEMINI_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
AI_PROVIDER=

# ─── Scan Limits ────────────────────────────────────────────
MAX_FILE_SIZE_MB=
MAX_SCAN_FILES=
UPLOAD_DIR=

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=

# ─── GitLab Integration (optional) ──────────────────────────
GITLAB_TOKEN=

# ─── Dependency Scanning APIs ───────────────────────────────
NVD_API_KEY=
OSV_API_URL=

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=
VITE_WS_URL=
