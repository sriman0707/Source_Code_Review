# ============================================================
# AI-Powered Secure Code Review Platform — Environment Config
# ============================================================
# Copy this file to .env and fill in your values.

# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=securereview
POSTGRES_USER=securereview
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── Application ────────────────────────────────────────────
SECRET_KEY=change_me_minimum_32_character_random_string_here
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── AI Engine ──────────────────────────────────────────────
# Option 1: Google Gemini (cloud, recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Ollama (local, offline/private)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AI provider selection: "gemini" | "ollama" | "none"
AI_PROVIDER=gemini

# ─── Scan Limits ────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_SCAN_FILES=1000
UPLOAD_DIR=./uploads

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=your_github_personal_access_token

# ─── GitLab Integration (optional) ──────────────────────────
GITLAB_TOKEN=your_gitlab_personal_access_token

# ─── Dependency Scanning APIs ───────────────────────────────
NVD_API_KEY=your_nvd_api_key_optional
OSV_API_URL=https://api.osv.dev/v1

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
